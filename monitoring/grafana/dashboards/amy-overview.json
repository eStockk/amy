      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "id": 13,
      "targets": [
        { "expr": "pg_stat_database_numbackends{job=\"amy-postgres\",datname=\"amy\"}", "legendFormat": "Connections" },
        { "expr": "rate(pg_stat_database_xact_commit{job=\"amy-postgres\",datname=\"amy\"}[5m])", "legendFormat": "Commits/sec" },
        { "expr": "rate(pg_stat_database_xact_rollback{job=\"amy-postgres\",datname=\"amy\"}[5m])", "legendFormat": "Rollbacks/sec" }
      ],
      "title": "PostgreSQL Activity",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
