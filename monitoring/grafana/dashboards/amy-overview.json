      "title": "VPS CPU",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 7,
      "targets": [
        { "expr": "sum(rate(amy_backend_http_requests_total[5m]))", "legendFormat": "Backend" },
        { "expr": "sum(rate(amy_frontend_http_requests_total[5m]))", "legendFormat": "Frontend" }
      ],
      "title": "Requests Per Second",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Service" },
            "properties": [{ "id": "custom.width", "value": 90 }]
          },
          {
            "matcher": { "id": "byName", "options": "IP" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          },
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [{ "id": "custom.width", "value": 90 }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(12, sum by (client_ip) (increase(amy_backend_http_requests_total{client_ip!=\"unknown\"}[15m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "Backend"
        },
        {
          "expr": "topk(12, sum by (client_ip) (increase(amy_frontend_http_requests_total{client_ip!=\"unknown\"}[15m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "Frontend"
        }
      ],
      "title": "Top Request Sources Last 15 Minutes",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "job": true,
              "method": true,
              "path": true,
              "status": true
            },
            "indexByName": {
              "Time": 0,
              "Metric": 1,
              "client_ip": 2,
              "Value": 3
            },
            "renameByName": {
              "Metric": "Service",
              "Value": "Requests",
              "client_ip": "IP"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "id": 10,
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(amy_backend_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Backend" },
        { "expr": "histogram_quantile(0.95, sum(rate(amy_frontend_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Frontend" }
      ],
      "title": "Response Time: 95% Requests Faster Than This",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "id": 11,
      "targets": [
        { "expr": "100 * (1 - node_memory_MemAvailable_bytes{job=\"amy-node\"} / node_memory_MemTotal_bytes{job=\"amy-node\"})", "legendFormat": "VPS RAM" },
        { "expr": "100 * (go_memstats_alloc_bytes{job=\"amy-backend\"} / 805306368)", "legendFormat": "Backend limit" },
        { "expr": "100 * (amy_frontend_process_resident_memory_bytes{job=\"amy-frontend\"} / 1073741824)", "legendFormat": "Frontend limit" }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "id": 12,
      "targets": [
        { "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{job=\"amy-node\",mode=\"idle\"}[5m])))", "legendFormat": "CPU total" },
        { "expr": "100 * avg(rate(node_cpu_seconds_total{job=\"amy-node\",mode=\"iowait\"}[5m]))", "legendFormat": "IO wait" }
      ],
      "title": "VPS CPU Load",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
