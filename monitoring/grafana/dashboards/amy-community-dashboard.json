      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "AmyPostgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_rp AS (SELECT DISTINCT ON (discord_id) discord_id, nickname, skin_url, status, created_at FROM rp_applications ORDER BY discord_id, created_at DESC), ticket_counts AS (SELECT LOWER(discord_nick) AS discord_nick, COUNT(*) AS tickets_total, COUNT(*) FILTER (WHERE status <> 'resolved') AS tickets_open FROM support_tickets WHERE discord_nick <> '' GROUP BY LOWER(discord_nick)), players AS (SELECT u.discord_id, COALESCE(NULLIF(u.global_name, ''), u.username) AS discord_name, COALESCE(NULLIF(u.linked_minecraft, ''), latest_rp.nickname, '') AS minecraft_name, latest_rp.skin_url, u.presence_active, u.last_seen_at, u.updated_at, COALESCE(ticket_counts.tickets_total, 0) AS tickets_total, COALESCE(ticket_counts.tickets_open, 0) AS tickets_open, COALESCE(latest_rp.status, 'missing') AS rp_status, COALESCE(array_to_string(member_state.roles, ', '), '') AS discord_roles, COALESCE(NULLIF(member_state.discord_status, ''), 'offline') AS discord_status FROM discord_users u LEFT JOIN latest_rp ON latest_rp.discord_id = u.discord_id LEFT JOIN ticket_counts ON ticket_counts.discord_nick IN (LOWER(u.username), LOWER(u.global_name)) LEFT JOIN discord_member_states member_state ON member_state.discord_id = u.discord_id) SELECT CASE WHEN skin_url <> '' THEN skin_url WHEN minecraft_name <> '' THEN 'https://minotar.net/armor/body/' || minecraft_name || '/100.png' ELSE '' END AS \"Скин\", discord_name AS \"Discord\", COALESCE(NULLIF(minecraft_name, ''), '-') AS \"Minecraft\", CASE WHEN last_seen_at >= NOW() - INTERVAL '5 minutes' THEN 'online' ELSE 'offline' END AS \"Сайт\", 'needs server sync' AS \"Minecraft online\", discord_status AS \"Discord online\", tickets_total AS \"Тикетов\", tickets_open AS \"Нерешённых\", rp_status AS \"RP статус\", CASE WHEN discord_roles <> '' THEN discord_roles ELSE '-' END AS \"Discord роли\" FROM players ORDER BY updated_at DESC LIMIT 200",
          "refId": "A"
        }
      ],
      "title": "Игроки: Discord, Minecraft, статусы, тикеты, RP",
      "type": "table"
    },
