      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "AmyPostgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT a.nickname AS \"Minecraft ник\", COALESCE(NULLIF(u.global_name, ''), u.username, a.discord_id) AS \"Discord\", a.created_at AS \"Дата публикации\", a.status AS \"Статус\", CASE WHEN u.last_seen_at >= NOW() - INTERVAL '5 minutes' THEN 'online' ELSE 'offline' END AS \"Онлайн на сайте\", COALESCE(NULLIF(member_state.discord_status, ''), 'offline') AS \"Онлайн в Discord\" FROM rp_applications a LEFT JOIN discord_users u ON u.discord_id = a.discord_id LEFT JOIN discord_member_states member_state ON member_state.discord_id = a.discord_id WHERE ('$rp_status' = 'all' OR ('$rp_status' = 'accepted' AND a.status IN ('accepted', 'approved')) OR ('$rp_status' = 'other' AND a.status NOT IN ('accepted', 'approved'))) ORDER BY a.created_at DESC LIMIT 200",
          "refId": "A"
        }
      ],
      "title": "RP-заявки: игрок, дата, статус, онлайн",
      "type": "table"
